# ============================================================
# FRONTEND (Angular)
# ============================================================

# Dependencias npm — nunca se suben al repo
frontend/node_modules/

# Build de producción generado por ng build
frontend/dist/

# Caché interna de Angular CLI (generada por ng serve/build)
frontend/.angular/

# Raíz — por si acaso
.angular/
.idea/
node_modules/
.claude/

# ============================================================
# BACKEND (Spring Boot / Maven)
# ============================================================

# Intellij IDEA project files
.idea/
*.iml

# Directorio de compilación de Maven
backend/target/

# Artefactos compilados Java
backend/**/*.class
backend/**/*.jar
backend/**/*.war

# Variables de entorno locales
backend/.env

# Configuración local con credenciales reales — NUNCA al repo
# Usa application-dev.example.yml como plantilla sin valores reales
backend/src/main/resources/application-dev.yml

